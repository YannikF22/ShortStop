{
  "manifest_version": 3,
  "name": "Short Stop",
  "version": "1.2",
  "description": "Control YouTube Shorts usage with soft, hard, and timed unlock modes.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}